                <p class="footer-desc">
                    Đồ ăn nhanh ngon, giao hàng siêu tốc trong 25 phút. Hương vị đậm đà, nguyên liệu tươi sạch mỗi ngày.
                </p>
                <div class="footer-socials">
                    <a href="#" aria-label="Facebook"><i class="ti ti-brand-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="ti ti-brand-instagram"></i></a>
                    <a href="#" aria-label="TikTok"><i class="ti ti-brand-tiktok"></i></a>
                    <a href="#" aria-label="YouTube"><i class="ti ti-brand-youtube"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Liên kết nhanh</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Thực đơn</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                    <li><a asp-controller="Order" asp-action="History">Lịch sử đơn</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Thực đơn</h4>
                <ul>
                    <li><a asp-controller="Product" asp-action="Index">Burger</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Pizza</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Gà rán</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Khoai tây chiên</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Tráng miệng</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Liên hệ</h4>
                <div class="footer-contact-item">
                    <i class="ti ti-map-pin"></i>
                    <span>281 Hai Bà Trưng, Phường 6,<br>Đà Lạt, Lâm Đồng</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-phone"></i>
                    <span>0931 323 316</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-mail"></i>
                    <span>hello@fastfood.vn</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-clock"></i>
                    <span>07:00 – 22:00 (Thứ 2 – CN)</span>
                </div>
            </div>

        </div>
        <div class="footer-bottom">
            <span>© 2026 FastFood. Đồ án Lập trình Web – Nhóm 2</span>
            <span>Đà Lạt, Lâm Đồng</span>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── THÔNG BÁO ĐƠN MỚI CHO ADMIN VÀ NHÂN VIÊN ── *@
    @if (User.Identity!.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("NhanVien")))
    {
        <style>
            #staffNotifBox {
                display: none;
                position: fixed;
                top: 20px;
                right: 20px;
                z-index: 99999;
                background: #fff;
                border: 2px solid #FF5C1A;
                border-radius: 16px;
                box-shadow: 0 12px 40px rgba(0,0,0,.18);
                min-width: 300px;
                max-width: 360px;
                overflow: hidden;
                animation: staffSlideIn .35s cubic-bezier(.21,1.02,.73,1) both;
            }

            .snf-header {
                background: linear-gradient(135deg, #FF5C1A, #FF8A50);
                padding: 12px 16px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .snf-icon {
                width: 36px;
                height: 36px;
                background: rgba(255,255,255,.2);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                flex-shrink: 0;
            }

            .snf-title {
                font-size: 13px;
                font-weight: 700;
                color: #fff;
                flex: 1;
            }

            .snf-close {
                background: rgba(255,255,255,.25);
                border: none;
                border-radius: 6px;
                color: #fff;
                cursor: pointer;
                font-size: 18px;
                width: 28px;
                height: 28px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .snf-body {
                padding: 14px 16px;
            }

            .snf-detail {
                font-size: 12px;
                color: #555;
                line-height: 1.6;
            }

            .snf-amount {
                font-size: 18px;
                font-weight: 700;
                color: #FF5C1A;
                margin: 6px 0;
            }

            .snf-actions {
                display: flex;
                gap: 8px;
                margin-top: 12px;
            }

            .snf-btn-view {
                flex: 1;
                background: #FF5C1A;
                color: #fff;
                border: none;
                border-radius: 8px;
                padding: 9px;
                font-size: 12px;
                font-weight: 600;
                cursor: pointer;
            }

                .snf-btn-view:hover {
                    background: #CC3D00;
                }

            .snf-btn-dismiss {
                background: #F4F5F7;
                color: #666;
                border: none;
                border-radius: 8px;
                padding: 9px 14px;
                font-size: 12px;
                cursor: pointer;
            }

                .snf-btn-dismiss:hover {
                    background: #E8E8E8;
                }

            .snf-progress {
                height: 3px;
                background: #FF5C1A;
                width: 100%;
                transform-origin: left;
                animation: snfProgress 90s linear forwards;
            }

            @@keyframes staffSlideIn {
                from {
                    opacity: 0;
                    transform: translateX(120%);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @@keyframes snfProgress {
                from {
                    transform: scaleX(1);
                }

                to {
                    transform: scaleX(0);
                }
            }
        </style>

        <div id="staffNotifBox">
            <div class="snf-header">
                <div class="snf-icon">🍔</div>
                <div class="snf-title">Đơn hàng mới!</div>
                <button class="snf-close" onclick="closeStaffNotif()">×</button>
            </div>
            <div class="snf-body">
                <div id="staffNotifDetail" class="snf-detail"></div>
                <div id="staffNotifAmount" class="snf-amount"></div>
                <div class="snf-actions">
                    <button class="snf-btn-view" onclick="goToOrders()">
                        🧾 Xem &amp; xác nhận đơn
                    </button>
                    <button class="snf-btn-dismiss" onclick="closeStaffNotif()">Bỏ qua</button>
                </div>
            </div>
            <div id="staffNotifProgress" class="snf-progress"></div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            let staffNotifTimeout;

            const staffHub = new signalR.HubConnectionBuilder()
                .withUrl("/orderHub")
                .withAutomaticReconnect()
                .build();

            staffHub.on("NewOrder", function (data) {
                document.getElementById("staffNotifDetail").innerHTML =
                    `Đơn <strong>#${data.orderId}</strong> · ${data.itemCount} món · ${data.address} · ${data.time}`;
                document.getElementById("staffNotifAmount").textContent = data.amount + "đ";

                const box = document.getElementById("staffNotifBox");
                box.style.display = "block";
                box.style.animation = "none";
                void box.offsetWidth;
                box.style.animation = "";

                const bar = document.getElementById("staffNotifProgress");
                bar.style.animation = "none";
                void bar.offsetWidth;
                bar.style.animation = "snfProgress 90s linear forwards";

                if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
                playStaffNotifSound();

                clearTimeout(staffNotifTimeout);
                staffNotifTimeout = setTimeout(closeStaffNotif, 90000);
            });

            staffHub.start().then(function () {
                staffHub.invoke("JoinStaffGroup");
            }).catch(function (err) {
                console.warn("SignalR (staff) connect error:", err);
            });

            function closeStaffNotif() {
                clearTimeout(staffNotifTimeout);
                const box = document.getElementById("staffNotifBox");
                box.style.transition = "opacity .3s, transform .3s";
                box.style.opacity = "0";
                box.style.transform = "translateX(120%)";
                setTimeout(function () {
                    box.style.display = "none";
                    box.style.transition = "";
                    box.style.opacity = "";
                    box.style.transform = "";
                }, 300);
            }

            function goToOrders() {
                closeStaffNotif();
                window.location.href = "/Admin/Admin/Orders";
            }

            function playStaffNotifSound() {
                try {
                    const ctx = new (window.AudioContext || window.webkitAudioContext)();
                    [523, 659, 784].forEach(function (freq, i) {
                        const osc = ctx.createOscillator();
                        const gain = ctx.createGain();
                        osc.connect(gain); gain.connect(ctx.destination);
                        osc.frequency.value = freq;
                        osc.type = "sine";
                        const t = ctx.currentTime + i * 0.12;
                        gain.gain.setValueAtTime(0.3, t);
                        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
                        osc.start(t); osc.stop(t + 0.35);
                    });
                } catch (e) { /* browser chặn audio */ }
            }
        </script>
    }
</body>
</html>