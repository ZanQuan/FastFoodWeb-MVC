@model FastFoodWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-card">
        <div class="auth-icon-wrap">
            <i class="ti ti-lock"></i>
        </div>
        <h2 class="auth-title">Đăng nhập</h2>

        <form asp-action="Login" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()

            @* Hiển thị thông báo lỗi tổng quát hệ thống từ ModelState *@
            <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-mail"></i>
                <input asp-for="Email" class="auth-input" placeholder="Email" />
                <span asp-validation-for="Email" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-key"></i>
                <input asp-for="Password" type="password" class="auth-input" placeholder="Mật khẩu" />
                <span asp-validation-for="Password" class="auth-error"></span>
            </div>

            <div class="auth-remember-row">
                <label class="auth-remember-label">
                    <input asp-for="RememberMe" type="checkbox" />
                    <span>Ghi nhớ đăng nhập</span>
                </label>
                <a asp-action="ForgotPassword" asp-controller="Account" class="auth-forgot">
                    Quên mật khẩu?
                </a>
            </div>

            <button type="submit" class="auth-submit-btn">
                Đăng nhập
            </button>
        </form>

        <p class="auth-switch">
            Chưa có tài khoản?
            <a asp-action="Register" asp-controller="Account">Đăng ký tại đây</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}