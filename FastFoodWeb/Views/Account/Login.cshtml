@model FastFoodWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}
<form asp-action="Login" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly"
         style="color:#E24B4A;font-size:13px;margin-bottom:12px"></div>
    <div style="margin-bottom:14px">
        <label asp-for="Email"
               style="font-size:13px;font-weight:500;display:block;margin-bottom:6px"></label>
        <input asp-for="Email" class="form-control" placeholder="email@example.com" />
        <span asp-validation-for="Email"
              style="color:#E24B4A;font-size:12px"></span>
    </div>
    <div style="margin-bottom:14px">
        <label asp-for="Password"
               style="font-size:13px;font-weight:500;display:block;margin-bottom:6px"></label>
        <input asp-for="Password" class="form-control" placeholder="••••••" />
        <span asp-validation-for="Password"
              style="color:#E24B4A;font-size:12px"></span>
    </div>
    <div style="margin-bottom:20px">
        <label style="font-size:13px;font-weight:500;display:flex;align-items:center;gap:8px">
            <input asp-for="RememberMe" type="checkbox" />
            Ghi nhớ đăng nhập
        </label>
    </div>
    <button type="submit" class="btn-order"
            style="width:100%;justify-content:center">
        Đăng nhập
    </button>
</form>

<div style="margin-top:20px;text-align:center;">
    <p style="font-size:14px;color:#666;margin-bottom:8px">
        Chưa có tài khoản?
        <a asp-action="Register" asp-controller="Account"
           style="color:#D96A3B;text-decoration:none;font-weight:500">
            Đăng ký tại đây
        </a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
