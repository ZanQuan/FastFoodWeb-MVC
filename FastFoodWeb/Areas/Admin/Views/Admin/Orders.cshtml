@model List<FastFoodWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    ViewData["ActiveMenu"] = "orders";

    string GetBg(string s) => s switch
    {
        "Hoàn thành" => "#E1F5EE",
        "Đang giao" => "#E6F1FB",
        "Đang xử lý" => "#FAEEDA",
        "Hủy" => "#FCEBEB",
        _ => "#F8F8F8"
    };
    string GetTc(string s) => s switch
    {
        "Hoàn thành" => "#085041",
        "Đang giao" => "#0C447C",
        "Đang xử lý" => "#633806",
        "Hủy" => "#A32D2D",
        _ => "#888"
    };

    var pending = Model.Count(o => o.Status == "Chờ xác nhận");
    var cooking = Model.Count(o => o.Status == "Đang xử lý");
    var shipping = Model.Count(o => o.Status == "Đang giao");
    var completed = Model.Count(o => o.Status == "Hoàn thành");
}

@* ── NOTIFICATION POPUP (SignalR) ── *@
<div id="notifBox"
     style="display:none;position:fixed;top:20px;right:20px;z-index:9999;
            background:#fff;border:1.5px solid #FF5C1A;border-radius:14px;
            padding:16px 20px;box-shadow:0 8px 32px rgba(0,0,0,.15);
            min-width:280px;max-width:340px">
    <div style="display:flex;align-items:flex-start;gap:12px">
        <div style="width:36px;height:36px;background:#FFF3E8;border-radius:10px;
                    display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="ti ti-bell-ringing" style="font-size:20px;color:#FF5C1A"></i>
        </div>
        <div style="flex:1">
            <div style="font-size:13px;font-weight:700;color:#111;margin-bottom:3px">
                🍔 Đơn hàng mới!
            </div>
            <div id="notifText" style="font-size:12px;color:#666"></div>
        </div>
        <button onclick="closeNotif()"
                style="background:none;border:none;cursor:pointer;color:#999;font-size:18px;
                       padding:0;line-height:1">
            ×
        </button>
    </div>
    <button onclick="window.location.reload()"
            style="width:100%;margin-top:12px;background:#FF5C1A;color:#fff;
                   border:none;border-radius:8px;padding:8px;font-size:12px;
                   font-weight:600;cursor:pointer">
        Xem ngay
    </button>
</div>

@* ── HEADER ── *@
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <div>
        <h2 style="font-size:18px;font-weight:600;margin-bottom:4px">
            Đơn hàng (@Model.Count)
        </h2>
        <p style="font-size:12px;color:#888">Quản lý và xử lý đơn hàng theo quy trình</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @if (pending > 0)
        {
            <div style="background:#FAEEDA;border-radius:8px;padding:8px 12px;text-align:center;position:relative">
                <div style="font-size:18px;font-weight:700;color:#BA7517">@pending</div>
                <div style="font-size:11px;color:#633806">Chờ xác nhận</div>
                <span style="position:absolute;top:-4px;right:-4px;width:10px;height:10px;
                                 background:#E24B4A;border-radius:50%;animation:blink 1s infinite"></span>
            </div>
        }
        <div style="background:#FAEEDA;border-radius:8px;padding:8px 12px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#D97706">@cooking</div>
            <div style="font-size:11px;color:#633806">Đang xử lý</div>
        </div>
        <div style="background:#E6F1FB;border-radius:8px;padding:8px 12px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#185FA5">@shipping</div>
            <div style="font-size:11px;color:#0C447C">Đang giao</div>
        </div>
        <div style="background:#E1F5EE;border-radius:8px;padding:8px 12px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#1D9E75">@completed</div>
            <div style="font-size:11px;color:#085041">Hoàn thành</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div style="background:#fff;border:1px solid #EAEAEA;border-radius:12px;
                    padding:60px;text-align:center;color:#888">
        <i class="ti ti-receipt-off"
           style="font-size:48px;opacity:.2;display:block;margin-bottom:12px"></i>
        Chưa có đơn hàng nào.
    </div>
}
else
{
    <div class="data-table">
        <table>
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Thời gian</th>
                    <th>Địa chỉ giao</th>
                    <th>Số món</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    bool isNew = o.Status == "Chờ xác nhận";
                    bool isCooking = o.Status == "Đang xử lý";
                    bool isShipping = o.Status == "Đang giao";
                    bool isDone = o.Status == "Hoàn thành" || o.Status == "Hủy";

                    <tr @(isNew? Html.Raw("style='background:#FFFBF5'") : Html.Raw(""))>
                        <td>
                            <strong style="color:#FF5C1A">#@o.Id</strong>
                            @if (isNew)
                            {
                                <span style="background:#E24B4A;color:#fff;font-size:9px;
                                                         font-weight:700;padding:2px 6px;border-radius:10px;
                                                         margin-left:4px">MỚI</span>
                            }
                        </td>
                        <td style="color:#666;font-size:12px">
                            @o.OrderDate.ToString("dd/MM")<br />
                            <strong>@o.OrderDate.ToString("HH:mm")</strong>
                        </td>
                        <td style="max-width:160px;overflow:hidden;
                                           text-overflow:ellipsis;white-space:nowrap"
                            title="@o.Address">
                            @o.Address
                        </td>
                        <td style="text-align:center">@o.OrderDetails.Count</td>
                        <td style="font-weight:600;color:#FF5C1A">
                            @o.TotalPrice.ToString("N0")đ
                        </td>
                        <td>
                            <span class="status-badge"
                                  style="background:@GetBg(o.Status);color:@GetTc(o.Status)">
                                @o.Status
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap">

                                @* Bước 1: Xác nhận → Đang xử lý *@
                                @if (isNew)
                                {
                                    <form asp-area="Admin" asp-controller="Admin"
                                          asp-action="ConfirmOrder" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <button type="submit" class="btn-admin btn-primary-a"
                                                title="Xác nhận đơn và bắt đầu làm">
                                            <i class="ti ti-check"></i> Xác nhận
                                        </button>
                                    </form>
                                }

                                @* Bước 2: Bếp xong → Đang giao *@
                                @if (isCooking)
                                {
                                    <form asp-area="Admin" asp-controller="Admin"
                                          asp-action="MarkDelivering" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <button type="submit" class="btn-admin"
                                                style="background:#E6F1FB;color:#185FA5"
                                                title="Giao hàng cho khách">
                                            <i class="ti ti-truck"></i> Giao hàng
                                        </button>
                                    </form>
                                }

                                @* Đang giao: chờ khách xác nhận *@
                                @if (isShipping)
                                {
                                    <span style="font-size:12px;color:#185FA5;
                                                             display:flex;align-items:center;gap:4px">
                                        <i class="ti ti-truck"></i> Chờ khách...
                                    </span>
                                }

                                @* Hoàn thành *@
                                @if (o.Status == "Hoàn thành")
                                {
                                    <span style="font-size:12px;color:#1D9E75;
                                                             display:flex;align-items:center;gap:4px">
                                        <i class="ti ti-circle-check"></i> Xong
                                    </span>
                                }

                                @* Hủy khi chưa giao *@
                                @if (!isDone)
                                {
                                    <form asp-area="Admin" asp-controller="Admin"
                                          asp-action="CancelOrder" method="post"
                                          onsubmit="return confirm('Hủy đơn #@o.Id?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <button type="submit" class="btn-admin btn-delete"
                                                title="Hủy đơn">
                                            <i class="ti ti-x"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0;
        }
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // SignalR: nhận thông báo đơn hàng mới
        const conn = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .withAutomaticReconnect()
            .build();

        conn.on("NewOrder", function(data) {
            document.getElementById("notifText").innerHTML =
                `Đơn #${data.orderId} · ${data.itemCount} món · <strong>${data.amount}đ</strong><br>
                 <small>${data.address} · ${data.time}</small>`;
            document.getElementById("notifBox").style.display = "block";

            // Rung notification
            if (navigator.vibrate) navigator.vibrate([200, 100, 200]);

            // Tự ẩn sau 15 giây
            setTimeout(closeNotif, 15000);
        });

        conn.start().then(function() {
            conn.invoke("JoinStaffGroup");
        });

        function closeNotif() {
            document.getElementById("notifBox").style.display = "none";
        }

        // Auto-refresh trang mỗi 30 giây để đồng bộ trạng thái
        setTimeout(() => window.location.reload(), 30000);
    </script>
}