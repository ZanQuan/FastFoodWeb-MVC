@model FastFoodWeb.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-card">
        <div class="auth-icon-wrap">
            <i class="ti ti-rotate-dot"></i> @* Icon vòng lặp làm mới mật khẩu phù hợp ngữ cảnh *@
        </div>
        <h2 class="auth-title">Đặt lại mật khẩu</h2>

        <p class="auth-switch" style="margin-bottom: 24px; color: var(--text-muted);">
            Tài khoản: <strong style="color: var(--brand);">@Model.Email</strong>
        </p>

        <form asp-action="ResetPassword" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()

            @* Sử dụng class error summary đồng bộ với site.css *@
            <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

            @* Giữ lại thẻ input hidden của Email hoặc Token nếu có phục vụ cho POST Action *@
            <input type="hidden" asp-for="Email" />

            <div class="auth-field">
                <i class="auth-field-icon ti ti-lock"></i>
                <input asp-for="NewPassword" type="password" class="auth-input" placeholder="Mật khẩu mới" />
                <span asp-validation-for="NewPassword" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-shield-check"></i>
                <input asp-for="ConfirmPassword" type="password" class="auth-input" placeholder="Xác nhận mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">
                Lưu mật khẩu mới
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}