@model FastFoodWeb.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-card">
        <div class="auth-icon-wrap">
            <i class="ti ti-help-circle"></i>
        </div>
        <h2 class="auth-title">Quên mật khẩu?</h2>

        @* Thêm style cho subtitle để hướng dẫn người dùng *@
        <p class="auth-switch" style="margin-bottom: 24px; color: var(--text-muted);">
            Nhập email tài khoản của bạn để nhận hướng dẫn khôi phục.
        </p>

        <form asp-action="ForgotPassword" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()

            @* Cấu trúc báo lỗi chuẩn của hệ thống *@
            <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-mail"></i>
                <input asp-for="Email" class="auth-input" placeholder="Nhập Email của bạn" />
                <span asp-validation-for="Email" class="auth-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">
                Gửi yêu cầu
            </button>
        </form>

        <p class="auth-switch">
            Nhớ ra mật khẩu rồi?
            <a asp-action="Login" asp-controller="Account">Quay lại Đăng nhập</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}