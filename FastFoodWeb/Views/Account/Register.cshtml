@{
    ViewData["Title"] = "Đăng ký";
}

<div class="login-container">
    <div class="login-card">
        <h2><i class="ti ti-user-plus"></i> Đăng ký tài khoản</h2>

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input name="email" id="email" class="form-control" placeholder="Nhập email..." />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Mật khẩu</label>
                <input name="password" id="password" type="password" class="form-control" placeholder="Nhập mật khẩu..." />
            </div>

            <button type="submit" class="btn-login">Đăng ký</button>
        </form>

        <div class="extra-link">
            Đã có tài khoản? <a asp-controller="Account" asp-action="Login">Đăng nhập ngay</a>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        }
    </div>
</div>
