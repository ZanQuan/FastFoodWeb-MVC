@model List<FastFoodWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    ViewData["ActiveMenu"] = "orders";

    string GetBg(string s) => s switch
    {
        "Hoàn thành" => "#E1F5EE",
        "Đang giao" => "#E6F1FB",
        "Hủy" => "#FCEBEB",
        _ => "#FAEEDA"
    };
    string GetTc(string s) => s switch
    {
        "Hoàn thành" => "#085041",
        "Đang giao" => "#0C447C",
        "Hủy" => "#A32D2D",
        _ => "#633806"
    };

    var pending = Model.Count(o => o.Status == "Chờ xác nhận");
    var shipping = Model.Count(o => o.Status == "Đang giao");
    var completed = Model.Count(o => o.Status == "Hoàn thành");
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <div>
        <h2 style="font-size:18px;font-weight:600;margin-bottom:4px">
            Đơn hàng (@Model.Count)
        </h2>
        <p style="font-size:12px;color:#888">
            Quản lý và cập nhật trạng thái đơn hàng
        </p>
    </div>
    <div style="display:flex;gap:10px">
        <div style="background:#FAEEDA;border-radius:8px;padding:8px 14px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#BA7517">@pending</div>
            <div style="font-size:11px;color:#633806">Chờ xác nhận</div>
        </div>
        <div style="background:#E6F1FB;border-radius:8px;padding:8px 14px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#185FA5">@shipping</div>
            <div style="font-size:11px;color:#0C447C">Đang giao</div>
        </div>
        <div style="background:#E1F5EE;border-radius:8px;padding:8px 14px;text-align:center">
            <div style="font-size:18px;font-weight:700;color:#1D9E75">@completed</div>
            <div style="font-size:11px;color:#085041">Hoàn thành</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div style="background:#fff;border:1px solid #EAEAEA;border-radius:12px;
                    padding:60px;text-align:center;color:#888">
        <i class="ti ti-receipt-off"
           style="font-size:48px;opacity:.2;display:block;margin-bottom:12px"></i>
        Chưa có đơn hàng nào.
    </div>
}
else
{
    <div class="data-table">
        <table>
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Địa chỉ giao</th>
                    <th>Số món</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Cập nhật</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td>
                            <strong style="color:#FF5C1A">#@o.Id</strong>
                        </td>
                        <td style="color:#666;font-size:12px">
                            @o.OrderDate.ToString("dd/MM/yyyy")<br />
                            @o.OrderDate.ToString("HH:mm")
                        </td>
                        <td style="max-width:180px;overflow:hidden;
                                           text-overflow:ellipsis;white-space:nowrap"
                            title="@o.Address">
                            @o.Address
                        </td>
                        <td style="text-align:center">
                            @o.OrderDetails.Count
                        </td>
                        <td style="font-weight:600;color:#FF5C1A">
                            @o.TotalPrice.ToString("N0")đ
                        </td>
                        <td>

                            <span class="status-badge"
                                  style="background:@GetBg(o.Status);color:@GetTc(o.Status)">
                                @o.Status
                            </span>
                        </td>
                        <td>
                            <form asp-area="Admin"
                                  asp-controller="Admin"
                                  asp-action="UpdateOrderStatus"
                                  method="post"
                                  style="display:flex;gap:6px;align-items:center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@o.Id" />

                                <select name="status"
                                        style="border:1px solid #E8E8E8;border-radius:6px;
                                                       padding:5px 8px;font-size:12px;background:#fff">
                                    @if (o.Status == "Chờ xác nhận")
                                    {
                                        <option value="Chờ xác nhận" selected>Chờ xác nhận</option>
                                    }
                                    else
                                    {
                                        <option value="Chờ xác nhận">Chờ xác nhận</option>
                                    }
                                    @if (o.Status == "Đang giao")
                                    {
                                        <option value="Đang giao" selected>Đang giao</option>
                                    }
                                    else
                                    {
                                        <option value="Đang giao">Đang giao</option>
                                    }
                                    @if (o.Status == "Hoàn thành")
                                    {
                                        <option value="Hoàn thành" selected>Hoàn thành</option>
                                    }
                                    else
                                    {
                                        <option value="Hoàn thành">Hoàn thành</option>
                                    }
                                    @if (o.Status == "Hủy")
                                    {
                                        <option value="Hủy" selected>Hủy</option>
                                    }
                                    else
                                    {
                                        <option value="Hủy">Hủy</option>
                                    }
                                </select>

                                <button type="submit" class="btn-admin btn-edit"
                                        title="Lưu thay đổi">
                                    <i class="ti ti-check"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}