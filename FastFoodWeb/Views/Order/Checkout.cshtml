@{
    ViewData["Title"] = "Đặt hàng";
    var cart = ViewBag.Cart as List<FastFoodWeb.Models.CartItem>;
    decimal total = ViewBag.Total;
}

<section class="section">
    <div class="container">

        <h2 style="margin-bottom:1.5rem; font-family:var(--font-head);
                   font-size:1.8rem; font-weight:800; color:var(--dark);">
            Đặt hàng
        </h2>

        <div class="checkout-grid">

            @* CỘT TRÁI: Form địa chỉ + phương thức thanh toán *@
            <div>
                <h4 style="margin-bottom:1.25rem; font-family:var(--font-head);
                           font-weight:700; color:var(--dark);">
                    Thông tin giao hàng
                </h4>

                <form asp-action="Checkout" method="post" id="checkoutForm">
                    @Html.AntiForgeryToken()

                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-weight:600;
                                      margin-bottom:6px; font-size:0.9rem;">
                            Địa chỉ giao hàng <span style="color:var(--brand);">*</span>
                        </label>
                        <input name="address" required
                               placeholder="Số nhà, đường, phường/xã, quận/huyện..."
                               style="width:100%; padding:10px 14px;
                                      border:1.5px solid var(--border);
                                      border-radius:var(--r-sm);
                                      font-size:0.95rem; outline:none;
                                      transition:border-color var(--t-base);
                                      box-sizing:border-box; background:#fff;"
                               onfocus="this.style.borderColor='var(--brand)'"
                               onblur="this.style.borderColor='var(--border)'" />
                    </div>

                    <div style="margin-bottom:1.5rem;">
                        <label style="display:block; font-weight:600;
                                      margin-bottom:6px; font-size:0.9rem;">
                            Ghi chú
                        </label>
                        <textarea name="note" rows="3"
                                  placeholder="Ghi chú thêm cho đơn hàng (không bắt buộc)..."
                                  style="width:100%; padding:10px 14px;
                                         border:1.5px solid var(--border);
                                         border-radius:var(--r-sm);
                                         font-size:0.95rem; outline:none; resize:vertical;
                                         transition:border-color var(--t-base);
                                         box-sizing:border-box; background:#fff;"
                                  onfocus="this.style.borderColor='var(--brand)'"
                                  onblur="this.style.borderColor='var(--border)'"></textarea>
                    </div>

                    @* ── PHƯƠNG THỨC THANH TOÁN ── *@
                    <div style="margin-bottom:1.75rem;">
                        <label style="display:block; font-weight:700;
                                      margin-bottom:12px; font-size:0.95rem; color:var(--dark);">
                            Phương thức thanh toán
                        </label>

                        <div class="pay-option" id="opt-cod" onclick="selectPay('COD')">
                            <input type="radio" name="paymentMethod" value="COD"
                                   id="pm-cod" checked hidden />
                            <div class="pay-icon" style="background:#fff8e1; color:#f59e0b;">
                                <i class="ti ti-cash"></i>
                            </div>
                            <div>
                                <div style="font-weight:700; color:var(--dark);">Thanh toán khi nhận hàng (COD)</div>
                                <div style="font-size:0.82rem; color:var(--text-muted);">Trả tiền mặt khi shipper giao hàng tận nơi</div>
                            </div>
                        </div>

                        <div class="pay-option" id="opt-vnpay" onclick="selectPay('VNPay')">
                            <input type="radio" name="paymentMethod" value="VNPay"
                                   id="pm-vnpay" hidden />
                            <div class="pay-icon" style="background:#e8f5e9; color:#1a8a3b;">
                                <i class="ti ti-credit-card"></i>
                            </div>
                            <div>
                                <div style="font-weight:700; color:var(--dark);">
                                    Thanh toán online qua VNPay
                                </div>
                                <div style="font-size:0.82rem; color:var(--text-muted);">
                                    Thẻ ATM, Visa, MasterCard, QR Code, Ví điện tử...
                                </div>
                            </div>
                            <div style="margin-left:auto; flex-shrink:0;">
                                <img src="https://sandbox.vnpayment.vn/paymentv2/images/bank/vnpayqr.png"
                                     alt="VNPay" style="height:28px; border-radius:4px;"
                                     onerror="this.style.display='none'" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn-order" style="width:100%;">
                        <i class="ti ti-check" id="btnIcon"></i>
                        <span id="btnText">Xác nhận đặt hàng</span>
                    </button>
                </form>
            </div>

            @* CỘT PHẢI: Tóm tắt đơn hàng *@
            <div>
                <h4 style="margin-bottom:1.25rem; font-family:var(--font-head);
                           font-weight:700; color:var(--dark);">
                    Tóm tắt đơn hàng
                </h4>

                <div style="background:#fff; border:1.5px solid var(--border);
                            border-radius:var(--r-lg); padding:1.25rem;
                            box-shadow:var(--shadow-xs);">

                    @foreach (var item in cart!)
                    {
                        <div style="display:flex; justify-content:space-between;
                                        align-items:center; padding:0.6rem 0;
                                        border-bottom:1px solid var(--border);">
                            <div>
                                <div style="font-weight:600; font-size:0.95rem; color:var(--dark);">
                                    @item.ProductName
                                </div>
                                <div style="font-size:0.82rem; color:var(--text-muted);">
                                    @item.Price.ToString("N0") VNĐ × @item.Quantity
                                </div>
                            </div>
                            <div style="font-weight:700; white-space:nowrap; color:var(--dark);">
                                @item.SubTotal.ToString("N0") VNĐ
                            </div>
                        </div>
                    }

                    <div style="display:flex; justify-content:space-between;
                                align-items:center; padding-top:1rem; margin-top:0.25rem;">
                        <span style="font-size:1rem; font-weight:700; color:var(--dark);">Tổng tiền</span>
                        <span style="font-size:1.2rem; font-weight:800; color:var(--brand);">
                            @total.ToString("N0") VNĐ
                        </span>
                    </div>
                </div>

                <p style="font-size:0.82rem; color:var(--text-faint);
                           margin-top:0.75rem; text-align:center;">
                    <i class="ti ti-truck"></i> Miễn phí giao hàng trong nội thành
                </p>

                @* Secure badge *@
                <div style="margin-top:1rem; padding:0.75rem; background:#f0fdf4;
                            border:1px solid #bbf7d0; border-radius:var(--r-sm);
                            display:flex; align-items:center; gap:8px; font-size:0.82rem; color:#166534;">
                    <i class="ti ti-shield-check" style="font-size:1.1rem;"></i>
                    Thanh toán bảo mật 100% qua VNPay SSL
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .checkout-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 2rem;
        align-items: start;
    }

    @@media (max-width: 768px) {
        .checkout-grid { grid-template-columns: 1fr; }
        .checkout-grid > div:last-child { order: -1; }
    }

    .pay-option {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border: 2px solid var(--border);
        border-radius: var(--r-sm);
        cursor: pointer;
        margin-bottom: 10px;
        transition: border-color 0.2s, background 0.2s;
        background: #fff;
    }

    .pay-option.selected {
        border-color: var(--brand);
        background: #fff8f0;
    }

    .pay-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
</style>

@section Scripts {
<script>
    // Khởi tạo trạng thái mặc định COD
    document.querySelector('#opt-cod').classList.add('selected');

    function selectPay(method) {
        // Cập nhật radio
        document.getElementById('pm-cod').checked   = method === 'COD';
        document.getElementById('pm-vnpay').checked = method === 'VNPay';

        // Cập nhật UI
        document.getElementById('opt-cod').classList.toggle('selected', method === 'COD');
        document.getElementById('opt-vnpay').classList.toggle('selected', method === 'VNPay');

        // Cập nhật nút
        const icon = document.getElementById('btnIcon');
        const text = document.getElementById('btnText');
        if (method === 'VNPay') {
            icon.className = 'ti ti-credit-card';
            text.textContent = 'Thanh toán qua VNPay';
        } else {
            icon.className = 'ti ti-check';
            text.textContent = 'Xác nhận đặt hàng';
        }
    }

    // Ngăn submit 2 lần
    document.getElementById('checkoutForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.style.opacity = '0.7';
    });
</script>
}
