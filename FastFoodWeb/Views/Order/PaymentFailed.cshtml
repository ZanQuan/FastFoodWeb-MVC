@model FastFoodWeb.Models.Order
@{
    ViewData["Title"] = "Thanh toán thất bại";
}

<section class="section">
    <div class="container">

        <div style="max-width:560px; margin:0 auto; text-align:center; padding:3rem 1rem;">

            <div style="font-size:72px; color:#ef4444; margin-bottom:1.25rem;">
                <i class="ti ti-circle-x"></i>
            </div>

            <h1 style="font-family:var(--font-head); font-size:1.8rem; font-weight:800;
                       color:var(--dark); margin-bottom:0.5rem;">
                Thanh toán không thành công
            </h1>

            <p style="color:var(--text-muted); font-size:1rem; line-height:1.7;
                      max-width:420px; margin:0 auto 2rem;">
                Giao dịch VNPay của đơn hàng <strong>#@Model.Id</strong> đã bị hủy
                hoặc không hoàn tất. Đơn hàng sẽ không được xử lý.
            </p>

            <div style="background:#fff; border:1.5px solid #fecaca;
                        border-radius:var(--r-lg); padding:1.5rem;
                        margin-bottom:2rem; text-align:left;">
                <div style="display:flex; justify-content:space-between; padding:0.4rem 0;
                            border-bottom:1px solid var(--border); font-size:0.9rem;">
                    <span style="color:var(--text-muted);">Mã đơn hàng</span>
                    <span style="font-weight:700;">#@Model.Id</span>
                </div>
                <div style="display:flex; justify-content:space-between; padding:0.4rem 0;
                            border-bottom:1px solid var(--border); font-size:0.9rem;">
                    <span style="color:var(--text-muted);">Số tiền</span>
                    <span style="font-weight:700;">@Model.TotalPrice.ToString("N0") VNĐ</span>
                </div>
                <div style="display:flex; justify-content:space-between; padding:0.4rem 0;
                            font-size:0.9rem;">
                    <span style="color:var(--text-muted);">Trạng thái</span>
                    <span style="font-weight:700; color:#ef4444;">Thất bại / Đã hủy</span>
                </div>
            </div>

            <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
                <a asp-controller="Cart" asp-action="Index"
                   class="btn-order"
                   style="text-decoration:none; display:inline-flex; align-items:center; gap:6px;">
                    <i class="ti ti-shopping-cart"></i> Quay lại giỏ hàng
                </a>
                <a asp-controller="Order" asp-action="History"
                   style="display:inline-flex; align-items:center; gap:6px;
                          padding:10px 20px; border:1.5px solid var(--border);
                          border-radius:var(--r-sm); color:var(--text);
                          text-decoration:none; font-weight:600; font-size:0.9rem;
                          background:#fff; transition:background 0.2s;"
                   onmouseover="this.style.background='#f5f5f5'"
                   onmouseout="this.style.background='#fff'">
                    <i class="ti ti-list"></i> Lịch sử đơn hàng
                </a>
            </div>

            <p style="margin-top:1.5rem; font-size:0.82rem; color:var(--text-faint);">
                Nếu tiền đã bị trừ, vui lòng liên hệ
                <a href="mailto:support@fastfood.vn" style="color:var(--brand);">support@fastfood.vn</a>
            </p>
        </div>

    </div>
</section>
