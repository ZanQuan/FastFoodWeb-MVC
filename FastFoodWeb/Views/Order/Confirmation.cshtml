@model FastFoodWeb.Models.Order
@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<section class="section">
    <div class="container">

        @* SUCCESS MESSAGE *@
        <div style="text-align:center; margin-bottom:3rem;">
            <div style="font-size:64px; color:#1D9E75; margin-bottom:1rem;">
                <i class="ti ti-circle-check"></i>
            </div>
            <h1 style="font-family:var(--font-head); font-size:2rem; font-weight:800;
                       color:var(--dark); margin-bottom:0.5rem;">
                Đặt hàng thành công!
            </h1>
            <p style="color:var(--text-muted); font-size:1rem; max-width:500px;
                      margin:0 auto; line-height:1.7;">
                Cảm ơn bạn đã đặt hàng. Chúng tôi sẽ xác nhận và giao hàng sớm nhất.
            </p>
        </div>

        @* ORDER CARD *@
        <div style="max-width:700px; margin:0 auto 3rem;
                    background:#fff; border:1.5px solid var(--border);
                    border-radius:var(--r-lg); padding:2rem;
                    box-shadow:var(--shadow-sm);">

            @* Header *@
            <div style="display:flex; justify-content:space-between; align-items:center;
                        padding-bottom:1.5rem; border-bottom:1px solid var(--border);">
                <div>
                    <p style="font-size:0.85rem; color:var(--text-faint);
                              text-transform:uppercase; font-weight:600; margin-bottom:4px;">
                        Mã đơn hàng
                    </p>
                    <p style="font-size:1.5rem; font-weight:700; color:var(--dark);">
                        #@Model.Id
                    </p>
                </div>
                <div style="text-align:right;">
                    <p style="font-size:0.85rem; color:var(--text-faint);
                              text-transform:uppercase; font-weight:600; margin-bottom:4px;">
                        Ngày đặt
                    </p>
                    <p style="font-size:1rem; font-weight:600; color:var(--text);">
                        @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                    </p>
                </div>
            </div>

            @* Trạng thái + Địa chỉ *@
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem;
                        padding:1.5rem 0; border-bottom:1px solid var(--border);">
                <div>
                    <label style="display:block; font-size:0.85rem; color:var(--text-faint);
                                  text-transform:uppercase; font-weight:600; margin-bottom:6px;">
                        Trạng thái
                    </label>
                    <div style="display:inline-flex; align-items:center; gap:8px;
                                background:var(--brand-light); padding:6px 14px;
                                border-radius:var(--r-sm); color:var(--brand); font-weight:600;">
                        <i class="ti ti-clock"></i>
                        @Model.Status
                    </div>
                </div>
                <div>
                    <label style="display:block; font-size:0.85rem; color:var(--text-faint);
                                  text-transform:uppercase; font-weight:600; margin-bottom:6px;">
                        Địa chỉ giao hàng
                    </label>
                    <p style="color:var(--text); font-size:0.95rem; line-height:1.6;">
                        @Model.Address
                    </p>
                </div>
            </div>

            @* Ghi chú *@
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div style="padding:1.5rem 0; border-bottom:1px solid var(--border);">
                    <label style="display:block; font-size:0.85rem; color:var(--text-faint);
                                      text-transform:uppercase; font-weight:600; margin-bottom:6px;">
                        Ghi chú
                    </label>
                    <p style="color:var(--text); font-size:0.95rem; line-height:1.6;">
                        @Model.Note
                    </p>
                </div>
            }

            @* Tổng tiền *@
            <div style="padding:1.5rem 0; border-bottom:1px solid var(--border);">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-size:1rem; font-weight:600; color:var(--text);">Tổng tiền</span>
                    <span style="font-size:1.75rem; font-weight:800; color:var(--brand);">
                        @Model.TotalPrice.ToString("N0") VNĐ
                    </span>
                </div>
            </div>

            @* Chi tiết món *@
            <div style="padding-top:1.5rem;">
                <h4 style="font-size:0.85rem; font-weight:700; color:var(--text-faint);
                           text-transform:uppercase; letter-spacing:0.08em; margin-bottom:1rem;">
                    Chi tiết đơn hàng
                </h4>

                @foreach (var item in Model.OrderDetails)
                {
                    <div style="display:flex; justify-content:space-between; align-items:center;
                                    padding:0.75rem 0; border-bottom:1px solid var(--border);">
                        <div>
                            <div style="font-weight:600; color:var(--dark); font-size:0.95rem;">
                                @item.Product?.Name
                            </div>
                            <div style="font-size:0.82rem; color:var(--text-muted);">
                                @item.UnitPrice.ToString("N0") VNĐ × @item.Quantity
                            </div>
                        </div>
                        <div style="font-weight:700; color:var(--dark);">
                            @((item.UnitPrice * item.Quantity).ToString("N0")) VNĐ
                        </div>
                    </div>
                }
            </div>

        </div>

        @* ACTION BUTTONS *@
        <div style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;
                    max-width:500px; margin:0 auto;">
            <a asp-controller="Home" asp-action="Index" class="btn-outline"
               style="flex:1; justify-content:center; min-width:160px;">
                <i class="ti ti-home"></i> Về trang chủ
            </a>
            <a asp-controller="Order" asp-action="History" class="btn-order"
               style="flex:1; justify-content:center; min-width:160px;">
                <i class="ti ti-history"></i> Lịch sử đơn hàng
            </a>
        </div>

    </div>
</section>