@using Microsoft.AspNetCore.Http

@{
    var cartJson = Context.Session.GetString("Cart");
    var cartCount = 0;
    if (!string.IsNullOrEmpty(cartJson))
    {
        try
        {
            var cartItems = System.Text.Json.JsonSerializer
                .Deserialize<List<FastFoodWeb.Models.CartItem>>(cartJson);
            cartCount = cartItems?.Sum(x => x.Quantity) ?? 0;
        }
        catch { cartCount = 0; }
    }
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – FastFood</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="topbar">
        <div class="topbar-inner">
            <div class="topbar-left">
                <span><i class="ti ti-phone"></i> 0987 654 321</span>
                <span><i class="ti ti-mail"></i> hello@fastfood.vn</span>
                <span><i class="ti ti-map-pin"></i> Đà Lạt, Lâm Đồng</span>
            </div>
            <div class="topbar-right">
                <a href="#" aria-label="Facebook"><i class="ti ti-brand-facebook"></i></a>
                <a href="#" aria-label="Instagram"><i class="ti ti-brand-instagram"></i></a>
                <a href="#" aria-label="TikTok"><i class="ti ti-brand-tiktok"></i></a>
                <a href="#" aria-label="YouTube"><i class="ti ti-brand-youtube"></i></a>
            </div>
        </div>
    </div>
>
    <nav class="navbar" id="mainNav">
        <div class="nav-inner">

            <a asp-controller="Home" asp-action="Index" class="logo">
                <div class="logo-circle">
                    <i class="ti ti-bolt"></i>
                </div>
                <div class="logo-text">
                    <span class="logo-name">Fast<span>Food</span></span>
                    <span class="logo-sub">Fast Food &amp; Restaurant</span>
                </div>
            </a>

            <ul class="nav-links">
                <li>
                    <a asp-controller="Home" asp-action="Index"
                       class="@(ctrl == "home" ? "active" : "")">
                        Trang chủ
                    </a>
                </li>
                <li>
                    <a asp-controller="Product" asp-action="Index"
                       class="@(ctrl == "product" ? "active" : "")">
                        Thực đơn
                    </a>
                </li>
                <li>
                    <a asp-controller="Order" asp-action="History"
                       class="@(ctrl == "order" ? "active" : "")">
                        Đơn hàng
                    </a>
                </li>
                @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <li>
                        <a asp-controller="Admin" asp-action="Index"
                           class="@(ctrl == "admin" ? "active" : "")">
                            Quản lý
                        </a>
                    </li>
                }
            </ul>

            <div class="nav-right">
                @if (User.Identity!.IsAuthenticated)
                {
                    @if (!User.IsInRole("Admin"))
                    {
                        <a asp-controller="Cart" asp-action="Index"
                           class="cart-btn" aria-label="Giỏ hàng">
                            <i class="ti ti-shopping-cart"></i>
                            @if (cartCount > 0)
                            {
                                <span class="cart-badge">@cartCount</span>
                            }
                        </a>
                    }
                    <form asp-controller="Account" asp-action="Logout"
                          method="post" style="display:inline">
                        <button type="submit" class="btn-order">
                            <i class="ti ti-logout"></i> Đăng xuất
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn-order">
                        <i class="ti ti-shopping-bag"></i> Đặt ngay
                    </a>
                }
            </div>

            <button class="hamburger" id="hamburger" aria-label="Mở menu">
                <span></span><span></span><span></span>
            </button>

        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="toast success" id="toastMsg">
            <i class="ti ti-circle-check"></i>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast error" id="toastMsg">
            <i class="ti ti-alert-circle"></i>
            @TempData["Error"]
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-grid">

            <div>
                <span class="footer-logo">Fast<span>Food</span></span>
                <p class="footer-desc">
                    Đồ ăn nhanh ngon, giao hàng siêu tốc trong 25 phút.Hương vị đậm đà, nguyên liệu tươi sạch mỗi ngày.
                </p>
                <div class="footer-socials">
                    <a href="#" aria-label="Facebook"><i class="ti ti-brand-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="ti ti-brand-instagram"></i></a>
                    <a href="#" aria-label="TikTok"><i class="ti ti-brand-tiktok"></i></a>
                    <a href="#" aria-label="YouTube"><i class="ti ti-brand-youtube"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Liên kết nhanh</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Thực đơn</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                    <li><a asp-controller="Order" asp-action="History">Lịch sử đơn</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Thực đơn</h4>
                <ul>
                    <li><a asp-controller="Product" asp-action="Index">Burger</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Pizza</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Gà rán</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Khoai tây chiên</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Tráng miệng</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Liên hệ</h4>
                <div class="footer-contact-item">
                    <i class="ti ti-map-pin"></i>
                    <span>42 Trần Phú, Phường 4,<br>Đà Lạt, Lâm Đồng</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-phone"></i>
                    <span>0987 654 321</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-mail"></i>
                    <span>hello@fastfood.vn</span>
                </div>
                <div class="footer-contact-item">
                    <i class="ti ti-clock"></i>
                    <span>07:00 – 22:00 (Thứ 2 – CN)</span>
                </div>
            </div>

        </div>
        <div class="footer-bottom">
            <span>© 2026 FastFood. Đồ án Lập trình Web – Nhóm 3</span>
            <span>Đà Lạt, Lâm Đồng</span>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
