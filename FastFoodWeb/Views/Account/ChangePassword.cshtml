@model FastFoodWeb.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-card">
        <div class="auth-icon-wrap">
            <i class="ti ti-lock-open"></i>
        </div>
        <h2 class="auth-title">Đổi mật khẩu</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form asp-action="ChangePassword" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-lock"></i>
                <input asp-for="CurrentPassword" type="password" class="auth-input"
                       placeholder="Mật khẩu hiện tại" />
                <span asp-validation-for="CurrentPassword" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-lock-plus"></i>
                <input asp-for="NewPassword" type="password" class="auth-input"
                       placeholder="Mật khẩu mới" />
                <span asp-validation-for="NewPassword" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-shield-check"></i>
                <input asp-for="ConfirmPassword" type="password" class="auth-input"
                       placeholder="Xác nhận mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">Lưu mật khẩu mới</button>
        </form>

        <p class="auth-switch">
            <a asp-action="Index" asp-controller="Home">← Quay về trang chủ</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}