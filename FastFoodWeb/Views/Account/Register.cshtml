@model FastFoodWeb.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-card">
        <div class="auth-icon-wrap">
            <i class="ti ti-user-plus"></i>
        </div>
        <h2 class="auth-title">Tạo tài khoản</h2>

        <form asp-action="Register" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()

            @* Sử dụng cấu trúc báo lỗi có khung của hệ thống *@
            <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-mail"></i>
                <input asp-for="Email" class="auth-input" placeholder="Địa chỉ Email" />
                <span asp-validation-for="Email" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-lock"></i>
                <input asp-for="Password" type="password" class="auth-input" placeholder="Mật khẩu mới" />
                <span asp-validation-for="Password" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <i class="auth-field-icon ti ti-shield-check"></i>
                <input asp-for="ConfirmPassword" type="password" class="auth-input" placeholder="Xác nhận mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">
                Đăng ký ngay
            </button>
        </form>

        <p class="auth-switch">
            Bạn đã là thành viên?
            <a asp-action="Login" asp-controller="Account">Đăng nhập tại đây</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}