@model List<FastFoodWeb.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<h2>Lịch sử đơn hàng</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Bạn chưa có đơn hàng nào.
    </div>
}
else
{
    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.Id</td>
                    <td>
                        @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td>
                        @item.TotalPrice.ToString("N0") VNĐ
                    </td>
                    <td>
                        @item.Status
                    </td>
                </tr>
            }
        </tbody>

    </table>
}