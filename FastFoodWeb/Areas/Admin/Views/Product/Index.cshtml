@model IEnumerable<FastFoodWeb.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    ViewData["ActiveMenu"] = "products";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Danh sách sản phẩm</h3>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn-admin btn-primary-a">
        <i class="ti ti-plus"></i> Thêm sản phẩm
    </a>
</div>
<div class="data-table">
    <table>
        <thead>
            <tr>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th width="180">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.ImageUrl" style="width:70px;height:70px;object-fit:cover;border-radius:8px;" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Category?.Name</td>
                    <td>
                        @String.Format("{0:N0}", item.Price) VNĐ
                    </td>
                    <td>@item.Stock</td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="status-badge" style="background:#E1F5EE;color:#0D7A5F;">Đang bán</span>
                        }
                        else
                        {
                            <span class="status-badge" style="background:#FCEBEB;color:#A32D2D;">Ngừng bán</span>
                        }
                    </td>
                    <td>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-admin btn-edit">
                            <i class="ti ti-edit"></i> Sửa
                        </a>
                        <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id"
                              method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-admin btn-delete"
                                    onclick="return confirm('Xóa sản phẩm này?')">
                                <i class="ti ti-trash"></i> Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
